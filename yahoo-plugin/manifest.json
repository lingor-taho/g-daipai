{
  "manifest_version": 3,
  "name": "Yahoo Auto Bid Agent",
  "version": "1.0.0",
  "permissions": ["alarms", "storage", "tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:3034/*",
    "http://localhost:3034/*",
    "https://*.yahoo.co.jp/*",
    "https://auctions.yahoo.co.jp/*",
    "https://*.auctions.yahoo.co.jp/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://auctions.yahoo.co.jp/*",
        "https://*.auctions.yahoo.co.jp/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Yahoo Auto Bid"
  }
}
